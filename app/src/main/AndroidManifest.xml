<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════════
         NETWORK PERMISSIONS
         Required for WifiManager interaction and LocalOnlyHotspot API
         ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Fine location is MANDATORY on Android 9 for LocalOnlyHotspot API.
         The OS requires it to prevent covert physical tracking via SSID scanning. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Required for NsdManager mDNS multicast broadcasts to pass through
         the Wi-Fi interface when the screen is disabled -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         STORAGE PERMISSIONS
         WRITE_EXTERNAL_STORAGE is declared for legacy compat; actual SD card
         root access is handled exclusively through SAF (Storage Access Framework)
         ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         BACKGROUND EXECUTION & POWER MANAGEMENT PERMISSIONS
         ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Foreground service grants immunity from OOM killer and memory culling -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- PARTIAL_WAKE_LOCK keeps CPU active during file transfer without
         forcing screen-on (avoids AMOLED burn-in on Galaxy S8+) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Required for BootReceiver to auto-restart the service after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         NOTIFICATION PERMISSION (Android 13+, harmless on API 28)
         ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidNetworkHub"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- ── Main Entry Activity ────────────────────────────────────────── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Hub Foreground Service ─────────────────────────────────────── -->
        <!-- dataSync: accurately classifies NAS file transfer behaviour for
             Google Play policy compliance and future Android 14 compatibility -->
        <service
            android:name=".service.HubForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync|connectedDevice"
            android:stopWithTask="false" />

        <!-- ── Boot Receiver ──────────────────────────────────────────────── -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
