<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon for Android 8.0+ (API 26+).
    The foreground layer uses the hub network icon against a solid dark background.
    Replace ic_launcher_foreground with your production asset.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_hub_notification" />
</adaptive-icon>
